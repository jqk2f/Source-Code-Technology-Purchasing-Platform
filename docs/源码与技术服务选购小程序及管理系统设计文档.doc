<h4>Banner 表 <code>banners</code></h4>
<table>
<tr><td>字段</td><td>类型</td><td>必填</td><td>说明</td></tr>
<tr><td><code>id</code></td><td>bigint unsigned</td><td>是</td><td>Banner ID</td></tr>
<tr><td><code>title</code></td><td>varchar(100)</td><td>是</td><td>标题</td></tr>
<tr><td><code>image_url</code></td><td>varchar(500)</td><td>是</td><td>图片</td></tr>
<tr><td><code>link_type</code></td><td>varchar(32)</td><td>是</td><td><code>product</code>，<code>service</code>，<code>article</code>，<code>url</code>，<code>none</code></td></tr>
<tr><td><code>link_value</code></td><td>varchar(255)</td><td>否</td><td>跳转值</td></tr>
<tr><td><code>position</code></td><td>varchar(32)</td><td>是</td><td>展示位置，如 <code>home</code></td></tr>
<tr><td><code>sort_no</code></td><td>int</td><td>是</td><td>排序</td></tr>
<tr><td><code>status</code></td><td>varchar(32)</td><td>是</td><td><code>enabled</code>，<code>disabled</code></td></tr>
<tr><td><code>start_at</code></td><td>datetime</td><td>否</td><td>开始时间</td></tr>
<tr><td><code>end_at</code></td><td>datetime</td><td>否</td><td>结束时间</td></tr>
<tr><td><code>created_at</code></td><td>datetime</td><td>是</td><td>创建时间</td></tr>
<tr><td><code>updated_at</code></td><td>datetime</td><td>是</td><td>更新时间</td></tr>
</table>
<h4>文章表 <code>articles</code></h4>
<table>
<tr><td>字段</td><td>类型</td><td>必填</td><td>说明</td></tr>
<tr><td><code>id</code></td><td>bigint unsigned</td><td>是</td><td>文章 ID</td></tr>
<tr><td><code>category_id</code></td><td>bigint unsigned</td><td>否</td><td>分类 ID</td></tr>
<tr><td><code>type</code></td><td>varchar(32)</td><td>是</td><td><code>help</code>，<code>notice</code>，<code>tutorial</code>，<code>agreement</code></td></tr>
<tr><td><code>title</code></td><td>varchar(128)</td><td>是</td><td>标题</td></tr>
<tr><td><code>summary</code></td><td>varchar(255)</td><td>否</td><td>摘要</td></tr>
<tr><td><code>content</code></td><td>longtext</td><td>是</td><td>内容</td></tr>
<tr><td><code>cover_url</code></td><td>varchar(500)</td><td>否</td><td>封面</td></tr>
<tr><td><code>status</code></td><td>varchar(32)</td><td>是</td><td><code>draft</code>，<code>published</code>，<code>hidden</code></td></tr>
<tr><td><code>sort_no</code></td><td>int</td><td>是</td><td>排序</td></tr>
<tr><td><code>published_at</code></td><td>datetime</td><td>否</td><td>发布时间</td></tr>
<tr><td><code>created_at</code></td><td>datetime</td><td>是</td><td>创建时间</td></tr>
<tr><td><code>updated_at</code></td><td>datetime</td><td>是</td><td>更新时间</td></tr>
</table>
<h3>4.25 消息表 <code>messages</code></h3>
<table>
<tr><td>字段</td><td>类型</td><td>必填</td><td>索引</td><td>说明</td></tr>
<tr><td><code>id</code></td><td>bigint unsigned</td><td>是</td><td>PK</td><td>消息 ID</td></tr>
<tr><td><code>receiver_type</code></td><td>varchar(32)</td><td>是</td><td>INDEX</td><td><code>customer</code>，<code>admin</code></td></tr>
<tr><td><code>receiver_id</code></td><td>bigint unsigned</td><td>是</td><td>INDEX</td><td>接收人</td></tr>
<tr><td><code>type</code></td><td>varchar(32)</td><td>是</td><td>INDEX</td><td><code>inquiry</code>，<code>order</code>，<code>payment</code>，<code>delivery</code>，<code>after_sale</code>，<code>system</code></td></tr>
<tr><td><code>title</code></td><td>varchar(128)</td><td>是</td><td></td><td>标题</td></tr>
<tr><td><code>content</code></td><td>varchar(1000)</td><td>是</td><td></td><td>内容</td></tr>
<tr><td><code>link_type</code></td><td>varchar(32)</td><td>否</td><td></td><td>跳转类型</td></tr>
<tr><td><code>link_id</code></td><td>bigint unsigned</td><td>否</td><td></td><td>跳转 ID</td></tr>
<tr><td><code>is_read</code></td><td>tinyint(1)</td><td>是</td><td>INDEX</td><td>是否已读</td></tr>
<tr><td><code>read_at</code></td><td>datetime</td><td>否</td><td></td><td>阅读时间</td></tr>
<tr><td><code>created_at</code></td><td>datetime</td><td>是</td><td>INDEX</td><td>创建时间</td></tr>
</table>
<h3>4.26 操作日志表 <code>operation_logs</code></h3>
<table>
<tr><td>字段</td><td>类型</td><td>必填</td><td>索引</td><td>说明</td></tr>
<tr><td><code>id</code></td><td>bigint unsigned</td><td>是</td><td>PK</td><td>日志 ID</td></tr>
<tr><td><code>operator_type</code></td><td>varchar(32)</td><td>是</td><td>INDEX</td><td><code>customer</code>，<code>admin</code>，<code>system</code></td></tr>
<tr><td><code>operator_id</code></td><td>bigint unsigned</td><td>否</td><td>INDEX</td><td>操作人</td></tr>
<tr><td><code>module</code></td><td>varchar(64)</td><td>是</td><td>INDEX</td><td>模块</td></tr>
<tr><td><code>action</code></td><td>varchar(64)</td><td>是</td><td>INDEX</td><td>动作</td></tr>
<tr><td><code>biz_type</code></td><td>varchar(64)</td><td>否</td><td>INDEX</td><td>业务类型</td></tr>
<tr><td><code>biz_id</code></td><td>bigint unsigned</td><td>否</td><td>INDEX</td><td>业务 ID</td></tr>
<tr><td><code>before_data</code></td><td>json</td><td>否</td><td></td><td>变更前</td></tr>
<tr><td><code>after_data</code></td><td>json</td><td>否</td><td></td><td>变更后</td></tr>
<tr><td><code>ip</code></td><td>varchar(64)</td><td>否</td><td></td><td>IP</td></tr>
<tr><td><code>user_agent</code></td><td>varchar(500)</td><td>否</td><td></td><td>UA</td></tr>
<tr><td><code>created_at</code></td><td>datetime</td><td>是</td><td>INDEX</td><td>创建时间</td></tr>
</table>
<h3>4.27 系统配置表 <code>system_configs</code></h3>
<table>
<tr><td>字段</td><td>类型</td><td>必填</td><td>索引</td><td>说明</td></tr>
<tr><td><code>id</code></td><td>bigint unsigned</td><td>是</td><td>PK</td><td>配置 ID</td></tr>
<tr><td><code>config_key</code></td><td>varchar(100)</td><td>是</td><td>UNIQUE</td><td>配置键</td></tr>
<tr><td><code>config_value</code></td><td>text</td><td>否</td><td></td><td>配置值</td></tr>
<tr><td><code>value_type</code></td><td>varchar(32)</td><td>是</td><td></td><td><code>string</code>，<code>number</code>，<code>boolean</code>，<code>json</code></td></tr>
<tr><td><code>description</code></td><td>varchar(255)</td><td>否</td><td></td><td>描述</td></tr>
<tr><td><code>is_public</code></td><td>tinyint(1)</td><td>是</td><td>INDEX</td><td>是否客户端可读取</td></tr>
<tr><td><code>created_at</code></td><td>datetime</td><td>是</td><td></td><td>创建时间</td></tr>
<tr><td><code>updated_at</code></td><td>datetime</td><td>是</td><td></td><td>更新时间</td></tr>
</table>
<h3>4.28 埋点事件表 <code>analytics_events</code></h3>
<table>
<tr><td>字段</td><td>类型</td><td>必填</td><td>索引</td><td>说明</td></tr>
<tr><td><code>id</code></td><td>bigint unsigned</td><td>是</td><td>PK</td><td>事件 ID</td></tr>
<tr><td><code>event_name</code></td><td>varchar(100)</td><td>是</td><td>INDEX</td><td>事件名</td></tr>
<tr><td><code>customer_id</code></td><td>bigint unsigned</td><td>否</td><td>INDEX</td><td>客户 ID</td></tr>
<tr><td><code>visitor_id</code></td><td>varchar(64)</td><td>否</td><td>INDEX</td><td>访客 ID</td></tr>
<tr><td><code>target_type</code></td><td>varchar(32)</td><td>否</td><td>INDEX</td><td>目标类型</td></tr>
<tr><td><code>target_id</code></td><td>bigint unsigned</td><td>否</td><td>INDEX</td><td>目标 ID</td></tr>
<tr><td><code>properties</code></td><td>json</td><td>否</td><td></td><td>扩展属性</td></tr>
<tr><td><code>source</code></td><td>varchar(64)</td><td>否</td><td>INDEX</td><td>来源</td></tr>
<tr><td><code>created_at</code></td><td>datetime</td><td>是</td><td>INDEX</td><td>事件时间</td></tr>
</table>
<h2>5. 接口规范</h2>
<h3>5.1 通用约定</h3>
<h4>请求约定</h4>
<table>
<tr><td>项目</td><td>说明</td></tr>
<tr><td>Base URL</td><td><code>/api/v1</code></td></tr>
<tr><td>Content-Type</td><td><code>application/json; charset=utf-8</code></td></tr>
<tr><td>文件上传</td><td><code>multipart/form-data</code></td></tr>
<tr><td>客户端鉴权</td><td><code>Authorization: Bearer &lt;customer_token&gt;</code></td></tr>
<tr><td>后台鉴权</td><td><code>Authorization: Bearer &lt;admin_token&gt;</code></td></tr>
<tr><td>时间格式</td><td><code>YYYY-MM-DD HH:mm:ss</code></td></tr>
<tr><td>分页参数</td><td><code>page</code> 默认 1，<code>pageSize</code> 默认 20，最大 100</td></tr>
</table>
<h4>通用响应</h4>
<pre><code>
{
  "code": 0,
  "message": "success",
  "data": {},
  "traceId": "202605211600001234"
}
</code></pre>
<h4>分页响应</h4>
<pre><code>
{
  "code": 0,
  "message": "success",
  "data": {
    "list": [],
    "page": 1,
    "pageSize": 20,
    "total": 100
  }
}
</code></pre>
<h4>常用错误码</h4>
<table>
<tr><td>错误码</td><td>说明</td></tr>
<tr><td><code>0</code></td><td>成功</td></tr>
<tr><td><code>400001</code></td><td>参数错误</td></tr>
<tr><td><code>401001</code></td><td>未登录或 Token 无效</td></tr>
<tr><td><code>403001</code></td><td>无权限</td></tr>
<tr><td><code>404001</code></td><td>数据不存在</td></tr>
<tr><td><code>409001</code></td><td>状态冲突，不允许当前操作</td></tr>
<tr><td><code>429001</code></td><td>请求过于频繁</td></tr>
<tr><td><code>500001</code></td><td>服务端异常</td></tr>
</table>
<h3>5.2 客户端接口</h3>
<h4>5.2.1 微信登录</h4>
<table>
<tr><td>项目</td><td>内容</td></tr>
<tr><td>Method</td><td><code>POST</code></td></tr>
<tr><td>Path</td><td><code>/mini/auth/wechat-login</code></td></tr>
<tr><td>Auth</td><td>否</td></tr>
</table>
<p>请求体：</p>
<pre><code>
{
  "code": "wx_login_code",
  "encryptedData": "optional",
  "iv": "optional"
}
</code></pre>
<p>响应：</p>
<pre><code>
{
  "token": "customer_token",
  "customer": {
    "id": 1,
    "nickname": "客户",
    "avatarUrl": "",
    "mobile": ""
  }
}
</code></pre>
<h4>5.2.2 获取个人资料</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/profile</code></td><td>客户</td></tr>
</table>
<p>响应字段：<code>id</code>、<code>nickname</code>、<code>avatarUrl</code>、<code>mobile</code>、<code>companyName</code>、<code>contactName</code>、<code>contactWechat</code>、<code>contactAddress</code>。</p>
<h4>5.2.3 更新个人资料</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>PUT</code></td><td><code>/mini/profile</code></td><td>客户</td></tr>
</table>
<p>请求体：</p>
<pre><code>
{
  "nickname": "客户",
  "avatarUrl": "https://example.com/avatar.png",
  "companyName": "某公司",
  "contactName": "张三",
  "contactWechat": "wechat_id",
  "contactAddress": "联系地址"
}
</code></pre>
<h4>5.2.4 首页数据</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/home</code></td><td>可选</td></tr>
</table>
<p>响应字段：<code>banners</code>、<code>categories</code>、<code>recommendedProducts</code>、<code>hotServices</code>、<code>latestProducts</code>、<code>bundles</code>、<code>articles</code>。</p>
<h4>5.2.5 分类列表</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/categories</code></td><td>否</td></tr>
</table>
<p>查询参数：</p>
<table>
<tr><td>参数</td><td>必填</td><td>说明</td></tr>
<tr><td><code>type</code></td><td>否</td><td><code>product</code>，<code>service</code>，<code>article</code></td></tr>
</table>
<h4>5.2.6 标签列表</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/tags</code></td><td>否</td></tr>
</table>
<p>查询参数：<code>type</code>、<code>isHot</code>。</p>
<h4>5.2.7 商品列表</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/products</code></td><td>否</td></tr>
</table>
<p>查询参数：</p>
<table>
<tr><td>参数</td><td>说明</td></tr>
<tr><td><code>keyword</code></td><td>搜索关键词</td></tr>
<tr><td><code>categoryId</code></td><td>分类 ID</td></tr>
<tr><td><code>tagIds</code></td><td>标签 ID，英文逗号分隔</td></tr>
<tr><td><code>priceMin</code> / <code>priceMax</code></td><td>价格区间</td></tr>
<tr><td><code>hasDemo</code></td><td>是否有演示</td></tr>
<tr><td><code>isDeployIncluded</code></td><td>是否含部署</td></tr>
<tr><td><code>isCustomizable</code></td><td>是否支持二开</td></tr>
<tr><td><code>sort</code></td><td><code>recommend</code>，<code>latest</code>，<code>price_asc</code>，<code>price_desc</code>，<code>views</code>，<code>deals</code></td></tr>
<tr><td><code>page</code> / <code>pageSize</code></td><td>分页</td></tr>
</table>
<p>列表项字段：<code>id</code>、<code>title</code>、<code>subtitle</code>、<code>coverUrl</code>、<code>price</code>、<code>startPrice</code>、<code>priceText</code>、<code>techStack</code>、<code>badges</code>、<code>viewCount</code>、<code>dealCount</code>、<code>isFavorite</code>。</p>
<h4>5.2.8 商品详情</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/products/{id}</code></td><td>可选</td></tr>
</table>
<p>响应字段：基础信息、分类、标签、轮播图、截图、功能清单、演示信息、部署要求、交付内容、购买须知、FAQ、关联服务、关联套餐、收藏状态。</p>
<h4>5.2.9 服务列表</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/services</code></td><td>否</td></tr>
</table>
<p>查询参数：<code>keyword</code>、<code>categoryId</code>、<code>tagIds</code>、<code>priceMin</code>、<code>priceMax</code>、<code>sort</code>、<code>page</code>、<code>pageSize</code>。</p>
<h4>5.2.10 服务详情</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/services/{id}</code></td><td>可选</td></tr>
</table>
<p>响应字段：服务名称、封面、起步价、周期、服务范围、流程、所需资料、交付标准、不包含内容、售后说明、套餐、收藏状态。</p>
<h4>5.2.11 收藏/取消收藏</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>POST</code></td><td><code>/mini/favorites</code></td><td>客户</td></tr>
<tr><td><code>DELETE</code></td><td><code>/mini/favorites</code></td><td>客户</td></tr>
</table>
<p>请求体：</p>
<pre><code>
{
  "targetType": "product",
  "targetId": 1
}
</code></pre>
<h4>5.2.12 收藏列表</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/favorites</code></td><td>客户</td></tr>
</table>
<p>查询参数：<code>targetType</code>、<code>page</code>、<code>pageSize</code>。</p>
<h4>5.2.13 创建购买意向/服务预约/定制需求</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>POST</code></td><td><code>/mini/inquiries</code></td><td>客户</td></tr>
</table>
<p>请求体：</p>
<pre><code>
{
  "sourceType": "product",
  "sourceId": 1,
  "title": "购买某商城源码",
  "demandType": "source_purchase",
  "description": "需要部署和简单讲解",
  "contactName": "张三",
  "contactMobile": "13800000000",
  "contactWechat": "wechat_id",
  "budgetMin": 1000,
  "budgetMax": 3000,
  "expectedFinishAt": "2026-05-30 18:00:00",
  "attachmentFileIds": [10, 11],
  "options": {
    "needDeploy": true,
    "needCustomization": false
  }
}
</code></pre>
<p>响应：<code>inquiryId</code>、<code>inquiryNo</code>、<code>status</code>。</p>
<h4>5.2.14 我的询单列表</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/inquiries</code></td><td>客户</td></tr>
</table>
<p>查询参数：<code>status</code>、<code>page</code>、<code>pageSize</code>。</p>
<h4>5.2.15 订单列表</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/orders</code></td><td>客户</td></tr>
</table>
<p>查询参数：<code>status</code>、<code>page</code>、<code>pageSize</code>。</p>
<h4>5.2.16 订单详情</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/orders/{id}</code></td><td>客户</td></tr>
</table>
<p>响应字段：订单基础信息、明细、金额、付款状态、付款说明、凭证记录、交付记录、售后入口、客户可见备注。</p>
<h4>5.2.17 上传付款凭证</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>POST</code></td><td><code>/mini/orders/{id}/payment-vouchers</code></td><td>客户</td></tr>
</table>
<p>请求体：</p>
<pre><code>
{
  "amount": 1999.00,
  "paymentMethod": "wechat_transfer",
  "paidAt": "2026-05-21 16:30:00",
  "voucherFileId": 100,
  "transactionNo": "optional",
  "remark": "已转账"
}
</code></pre>
<p>响应：<code>paymentRecordId</code>、<code>status</code>。</p>
<h4>5.2.18 交付记录列表</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/orders/{id}/deliveries</code></td><td>客户</td></tr>
</table>
<p>权限：只能查看本人订单，且仅返回 <code>isCustomerVisible = true</code> 的交付记录。</p>
<h4>5.2.19 确认交付</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>POST</code></td><td><code>/mini/deliveries/{id}/confirm</code></td><td>客户</td></tr>
</table>
<p>响应：<code>deliveryStatus</code>、<code>orderStatus</code>。</p>
<h4>5.2.20 创建售后工单</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>POST</code></td><td><code>/mini/after-sales</code></td><td>客户</td></tr>
</table>
<p>请求体：</p>
<pre><code>
{
  "orderId": 1,
  "deliveryId": 2,
  "type": "source_run_issue",
  "title": "源码运行报错",
  "description": "本地启动后接口报错",
  "environment": "Node.js 20, MySQL 8",
  "attachmentFileIds": [101, 102]
}
</code></pre>
<h4>5.2.21 售后详情与回复</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td><td>说明</td></tr>
<tr><td><code>GET</code></td><td><code>/mini/after-sales/{id}</code></td><td>客户</td><td>查看售后详情</td></tr>
<tr><td><code>POST</code></td><td><code>/mini/after-sales/{id}/messages</code></td><td>客户</td><td>追加回复</td></tr>
</table>
<h4>5.2.22 文件上传</h4>
<table>
<tr><td>Method</td><td>Path</td><td>Auth</td></tr>
<tr><td><code>POST</code></td><td><code>/mini/files</code></td><td>客户</td></tr>
</table>
<p>表单字段：<code>file</code>、<code>bizType</code>。  </p>
<p>返回：<code>fileId</code>、<code>url</code>、<code>originalName</code>、<code>sizeBytes</code>。</p>
